#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/gpio/gpio.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        //zmk,physical-layout = &gaggs_kyria_layout; 
    };

    zmk_studio: zmk_studio {
        compatible = "zmk,studio";
    };

    gaggs_kyria_layout: gaggs_kyria_layout {
        compatible = "zmk,physical-layout";
        display-name = "Gaggs Kyria Layout";
        transform = <&default_transform>; 
        kscan = <&kscan0>;

     /* 50키 완벽 대응 (좌우 교차 순서 적용 + 엄지 회전 복구) */
        keys
            /* ================= Row 0 (12키: 좌 6 + 우 6) ================= */
            /* 왼쪽 Row 0 (1~6번 키) */
            = <&key_physical_attrs 100 100 0 50 0 0 0>
            , <&key_physical_attrs 100 100 100 25 0 0 0>
            , <&key_physical_attrs 100 100 200 0 0 0 0>
            , <&key_physical_attrs 100 100 300 25 0 0 0>
            , <&key_physical_attrs 100 100 400 50 0 0 0>
            , <&key_physical_attrs 100 100 500 75 0 0 0>
            /* 오른쪽 Row 0 (7~12번 키: Y, U, I, O, P, \) */
            , <&key_physical_attrs 100 100 1200 75 0 0 0>
            , <&key_physical_attrs 100 100 1300 50 0 0 0>
            , <&key_physical_attrs 100 100 1400 25 0 0 0>
            , <&key_physical_attrs 100 100 1500 0 0 0 0>
            , <&key_physical_attrs 100 100 1600 25 0 0 0>
            , <&key_physical_attrs 100 100 1700 50 0 0 0>

            /* ================= Row 1 (12키: 좌 6 + 우 6) ================= */
            /* 왼쪽 Row 1 (13~18번 키) */
            , <&key_physical_attrs 100 100 0 150 0 0 0>
            , <&key_physical_attrs 100 100 100 125 0 0 0>
            , <&key_physical_attrs 100 100 200 100 0 0 0>
            , <&key_physical_attrs 100 100 300 125 0 0 0>
            , <&key_physical_attrs 100 100 400 150 0 0 0>
            , <&key_physical_attrs 100 100 500 175 0 0 0>
            /* 오른쪽 Row 1 (19~24번 키) */
            , <&key_physical_attrs 100 100 1200 175 0 0 0>
            , <&key_physical_attrs 100 100 1300 150 0 0 0>
            , <&key_physical_attrs 100 100 1400 125 0 0 0>
            , <&key_physical_attrs 100 100 1500 100 0 0 0>
            , <&key_physical_attrs 100 100 1600 125 0 0 0>
            , <&key_physical_attrs 100 100 1700 150 0 0 0>

            /* ================= Row 2 (12키: 좌 6 + 우 6) ================= */
            /* 왼쪽 Row 2 (25~30번 키) */
            , <&key_physical_attrs 100 100 0 250 0 0 0>
            , <&key_physical_attrs 100 100 100 225 0 0 0>
            , <&key_physical_attrs 100 100 200 200 0 0 0>
            , <&key_physical_attrs 100 100 300 225 0 0 0>
            , <&key_physical_attrs 100 100 400 250 0 0 0>
            , <&key_physical_attrs 100 100 500 275 0 0 0>
            /* 오른쪽 Row 2 (31~36번 키) */
            , <&key_physical_attrs 100 100 1200 275 0 0 0>
            , <&key_physical_attrs 100 100 1300 250 0 0 0>
            , <&key_physical_attrs 100 100 1400 225 0 0 0>
            , <&key_physical_attrs 100 100 1500 200 0 0 0>
            , <&key_physical_attrs 100 100 1600 225 0 0 0>
            , <&key_physical_attrs 100 100 1700 250 0 0 0>

            /* ================= Row 3 엄지 블록 (14키: 좌 7 + 우 7) ================= */
            /* 왼쪽 엄지 (37~43번 키: 회전각 15, 30, 45도 및 피벗점 부활) */
            , <&key_physical_attrs 100 100 0 350 0 0 0>
            , <&key_physical_attrs 100 100 100 350 0 0 0>
            , <&key_physical_attrs 100 100 250 250 0 0 0>
            , <&key_physical_attrs 100 100 300 350 0 0 0>
            , <&key_physical_attrs 100 100 450 375 15 500 425>
            , <&key_physical_attrs 100 100 550 425 30 600 475>
            , <&key_physical_attrs 100 100 650 480 45 700 530>

            /* 오른쪽 엄지 (44~50번 키: 사진의 부채꼴 대칭 복구, 마이너스 괄호 처리 완료) */
            , <&key_physical_attrs 100 100 1050 480 (-45) 1100 530>
            , <&key_physical_attrs 100 100 1150 425 (-30) 1200 475>
            , <&key_physical_attrs 100 100 1250 375 (-15) 1300 425>
            , <&key_physical_attrs 100 100 1400 350 0 0 0>
            , <&key_physical_attrs 100 100 1450 250 0 0 0>
            , <&key_physical_attrs 100 100 1600 350 0 0 0>
            , <&key_physical_attrs 100 100 1700 250 0 0 0>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <4>;
          map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                          RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                          RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)        RC(2,7)   RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
        RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)        RC(3,7)   RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        row-gpios
        = <&pro_micro 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        ;
    };
};